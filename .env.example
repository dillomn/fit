# Copy to .env and fill in. The .env file is gitignored.

# SQLite database location (Prisma). For Docker this points at the mounted volume.
DATABASE_URL="file:./prisma/dev.db"

# The single password used to log into the app.
APP_PASSWORD="change-me"

# Secret used to sign the session cookie. Generate with: openssl rand -hex 32
SESSION_SECRET="change-me-to-a-long-random-string"
